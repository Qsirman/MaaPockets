{
    "interface_version": 2,
    "name": "MaaPockets",
    "description": "《口袋奇兵》Top War AFK 自动运营系统",
    "version": "1.0.0",
    "controller": [
        {
            "name": "安卓端",
            "type": "Adb",
            "display_short_side": 720
        }
    ],
    "resource": [
        {
            "name": "默认资源",
            "path": [
                "./resource"
            ]
        }
    ],
    "agent": {
        "child_exec": "python",
        "child_args": [
            "./agent/main.py"
        ]
    },
    "task": [
        {
            "name": "AFK全自动运营",
            "entry": "StartAFK",
            "option": [
                "运营强度",
                "体力药水策略",
                "背包开箱保护"
            ]
        },
        {
            "name": "每日任务",
            "entry": "StartDailyTasks",
            "option": [
                "岛屿大作战开关"
            ]
        },
        {
            "name": "雷达清场",
            "entry": "StartRadar",
            "option": [
                "雷达空刷策略",
                "体力药水策略"
            ]
        },
        {
            "name": "合并引擎",
            "entry": "StartMerge"
        },
        {
            "name": "外勤派遣",
            "entry": "StartExpedition",
            "option": [
                "卡车品质门槛",
                "背包开箱保护"
            ]
        }
    ],
    "option": {
        "运营强度": {
            "type": "select",
            "cases": [
                {
                    "name": "轻度",
                    "pipeline_override": {
                        "StartAFK": {
                            "custom_recognition_param": {
                                "intensity": "轻度"
                            }
                        }
                    }
                },
                {
                    "name": "标准",
                    "pipeline_override": {
                        "StartAFK": {
                            "custom_recognition_param": {
                                "intensity": "标准"
                            }
                        }
                    }
                },
                {
                    "name": "激进",
                    "pipeline_override": {
                        "StartAFK": {
                            "custom_recognition_param": {
                                "intensity": "激进"
                            }
                        }
                    }
                }
            ],
            "default_case": "标准"
        },
        "体力药水策略": {
            "type": "switch",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "StartAFK": {
                            "custom_recognition_param": {
                                "allow_potion": true
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "StartAFK": {
                            "custom_recognition_param": {
                                "allow_potion": false
                            }
                        }
                    }
                }
            ],
            "default_case": "No"
        },
        "背包开箱保护": {
            "type": "switch",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "StartExpedition": {
                            "custom_recognition_param": {
                                "inventory_protect": true
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "StartExpedition": {
                            "custom_recognition_param": {
                                "inventory_protect": false
                            }
                        }
                    }
                }
            ],
            "default_case": "Yes"
        },
        "卡车品质门槛": {
            "type": "select",
            "cases": [
                {
                    "name": "R",
                    "pipeline_override": {
                        "StartExpedition": {
                            "custom_recognition_param": {
                                "truck_min_quality": "R"
                            }
                        }
                    }
                },
                {
                    "name": "SR",
                    "pipeline_override": {
                        "StartExpedition": {
                            "custom_recognition_param": {
                                "truck_min_quality": "SR"
                            }
                        }
                    }
                },
                {
                    "name": "SSR",
                    "pipeline_override": {
                        "StartExpedition": {
                            "custom_recognition_param": {
                                "truck_min_quality": "SSR"
                            }
                        }
                    }
                }
            ],
            "default_case": "SR"
        },
        "雷达空刷策略": {
            "type": "switch",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "StartRadar": {
                            "custom_recognition_param": {
                                "use_free_refresh": true
                            }
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "StartRadar": {
                            "custom_recognition_param": {
                                "use_free_refresh": false
                            }
                        }
                    }
                }
            ],
            "default_case": "Yes"
        },
        "岛屿大作战开关": {
            "type": "switch",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "Daily_IslandBattle": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "Daily_IslandBattle": {
                            "enabled": false
                        }
                    }
                }
            ],
            "default_case": "Yes"
        }
    }
}